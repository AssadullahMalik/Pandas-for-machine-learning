import pandas as pd
import numpy as np

# Create dataset
df = pd.DataFrame({
    "Name": ["Ali", "Ahmed", "Sara", "Zara"],
    "Marks": np.random.randint(50, 100, 4)
})

print("Dataset:\n", df)

# Analysis
print("Average Marks:", df["Marks"].mean())
print("Top Student:\n", df[df["Marks"] == df["Marks"].max()])
print("Sorted:\n", df.sort_values(by="Marks", ascending=False))
